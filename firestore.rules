rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNonEmptyString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function isOptionalString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function isIsoTimestamp(value) {
      return value is string
        && value.size() >= 20
        && value.size() <= 40
        && value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*Z$');
    }

    function validProfile(profile) {
      return profile is map
        && profile.keys().hasOnly(['email', 'displayName', 'photoURL'])
        && isOptionalString(profile.get('email', null), 320)
        && isOptionalString(profile.get('displayName', null), 120)
        && isOptionalString(profile.get('photoURL', null), 2048);
    }

    function validPreferredTime(value) {
      return value is string && value.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$');
    }

    function validWeekday(value) {
      return value in [
        'monday',
        'tuesday',
        'wednesday',
        'thursday',
        'friday',
        'saturday',
        'sunday',
      ];
    }

    function validPreferences(preferences) {
      return preferences is map
        && preferences.keys().hasOnly([
          'language',
          'interests',
          'digestTone',
          'digestFrequency',
          'preferredWeekday',
          'preferredTime',
          'timezone',
        ])
        && preferences.language in ['en', 'pl', 'uk']
        && preferences.interests is list
        && preferences.interests.size() > 0
        && preferences.interests.size() <= 9
        && preferences.interests.hasOnly([
          'react',
          'ai',
          'frontend',
          'architecture',
          'leadership',
          'platform',
          'security',
          'performance',
          'cloud',
        ])
        && preferences.digestTone in ['executive', 'balanced', 'technical']
        && preferences.digestFrequency in [
          'daily',
          'twicePerWeek',
          'weekly',
          'biweekly',
          'monthly',
        ]
        && validPreferredTime(preferences.preferredTime)
        && isNonEmptyString(preferences.timezone, 80)
        && (
          (preferences.digestFrequency == 'daily' && preferences.preferredWeekday == null)
          || (
            preferences.digestFrequency != 'daily'
            && preferences.preferredWeekday != null
            && validWeekday(preferences.preferredWeekday)
          )
        );
    }

    function validUserDocumentKeys(data) {
      return data.keys().hasOnly([
        'profile',
        'preferences',
        'createdAt',
        'updatedAt',
        'latestDigestId',
        'nextDigestDueAt',
      ]);
    }

    function protectedDigestPointersUnchanged() {
      return request.resource.data.get('latestDigestId', null)
          == resource.data.get('latestDigestId', null)
        && request.resource.data.get('nextDigestDueAt', null)
          == resource.data.get('nextDigestDueAt', null);
    }

    function protectedCreatedAtUnchanged() {
      return request.resource.data.createdAt == resource.data.createdAt;
    }

    function validUserCreate() {
      let data = request.resource.data;

      return validUserDocumentKeys(data)
        && validProfile(data.profile)
        && data.get('latestDigestId', null) == null
        && data.get('nextDigestDueAt', null) == null
        && (!('preferences' in data) || data.preferences == null || validPreferences(data.preferences));
    }

    function validUserUpdate() {
      let data = request.resource.data;
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();

      return validUserDocumentKeys(data)
        && validProfile(data.profile)
        && protectedDigestPointersUnchanged()
        && protectedCreatedAtUnchanged()
        && changedKeys.hasOnly(['profile', 'preferences', 'updatedAt'])
        && (!('preferences' in data) || data.preferences == null || validPreferences(data.preferences));
    }

    function validSavedItem(data) {
      return data.keys().hasOnly([
        'itemId',
        'digestId',
        'title',
        'sourceId',
        'sourceLabel',
        'citationUrl',
        'savedAt',
      ])
        && isNonEmptyString(data.itemId, 200)
        && isNonEmptyString(data.digestId, 200)
        && isNonEmptyString(data.title, 500)
        && isNonEmptyString(data.sourceId, 120)
        && isNonEmptyString(data.sourceLabel, 200)
        && isNonEmptyString(data.citationUrl, 2048)
        && isIsoTimestamp(data.savedAt);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && validUserCreate();
      allow update: if isOwner(userId) && validUserUpdate();
      allow delete: if false;

      match /digests/{digestId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /savedItems/{itemId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validSavedItem(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /generationRuns/{runId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }
  }
}
