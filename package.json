{
  "name": "signalforge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run && npm run test:rules && npm run functions:test",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "functions:test": "npm --prefix functions run test",
    "test:coverage": "vitest run --coverage",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules --project signalforge-msdev",
    "functions:build": "npm --prefix functions run build",
    "functions:typecheck": "npm --prefix functions run typecheck",
    "firebase:deploy:functions": "firebase deploy --only functions --project signalforge-msdev",
    "firebase:deploy:hosting": "npm run build && firebase deploy --only hosting --project signalforge-msdev",
    "validate": "npm run typecheck && npm run lint && npm test && npm run build && npm run functions:build"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.1.3",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase-tools": "^13.29.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
